{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ],
  "rewrites": [],
  "redirects": [],
  "routes": [
    { "src": "/references/(.*)", "status": 404, "dest": "/404" },
    { "src": "/.*\\.md$", "status": 404, "dest": "/404" },
    { "src": "/CLAUDE(.*)", "status": 404, "dest": "/404" },
    { "src": "/brand\\.md", "status": 404, "dest": "/404" },
    { "src": "/principles\\.md", "status": 404, "dest": "/404" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
